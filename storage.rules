rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{fileName} {
      // Only allow users to upload their own avatars
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // In our UserProfilePanel.jsx, we upload to `avatars/${user.uid}.${fileExtension}`
    // Let's make sure the rules match the path we are using
    match /avatars/{fileName} {
      allow read: if true;
      // We can check if the fileName starts with the userId
      allow write: if request.auth != null && fileName.matches(request.auth.uid + '.*');
    }

    // Chat image sharing - authenticated users can upload and read
    match /chat_images/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
