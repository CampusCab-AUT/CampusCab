rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Lock down by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Prevent self-escalation: users cannot touch role or suspension fields
      allow update: if request.auth != null && request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'suspended', 'suspendedUntil', 'suspendedReason']);
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow read, create, update: if isAdmin();
    }

    // Trips
    match /trips/{tripId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.driverId || isAdmin()
      );
      // Any signed-in passenger may respond to a safety check-in by writing
      // ONLY the safetyCheckIn field on the trip they are on. Trip flagging on
      // help-requested is performed by the Cloud Function (Admin SDK).
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['safetyCheckIn']);
    }

    // Ride Requests
    match /rideRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.tripOwnerId ||
        isAdmin()
      );
      // Enforce that the requester is filing on their own behalf
      allow create: if request.auth != null &&
        request.resource.data.passengerId == request.auth.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.tripOwnerId
      );
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.recipientId;
      // Authenticated users can create notifications for others (e.g. driver notifying passenger)
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow delete: if isAdmin();
    }

    // Push Tokens — split write so delete uses resource.data (not request.resource.data)
    match /pushTokens/{tokenId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Vehicles — split write so delete uses resource.data (not request.resource.data)
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // Ratings — prevent self-rating and impersonation
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.raterId == request.auth.uid &&
        request.resource.data.raterId != request.resource.data.ratedUserId;
    }

    // Reports — passengers/drivers can file; only admins can read or update.
    // Passengers may additionally read their own SAFETY_ALERT reports so the
    // UI can reflect the alert state.
    match /reports/{reportId} {
      allow create: if request.auth != null &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.status == 'New';
      allow read: if request.auth != null &&
        resource.data.category == 'SAFETY_ALERT' &&
        resource.data.reporterId == request.auth.uid;
      allow read, update: if isAdmin();
    }

    // Audit logs — admin read; backend (Admin SDK) handles writes, bypassing rules
    match /auditLogs/{logId} {
      allow read, create: if isAdmin();
    }
    
    // Chats — Allow authenticated users to send, receive, and update (for read receipts & emojis)
    match /chats/{chatId}/messages/{messageId} {
      allow read, create, update: if request.auth != null;
    }
    
    // Calls (Real-time signaling)
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }

    // Route Alerts — passengers manage their own; admins can read for moderation
    match /routeAlerts/{alertId} {
      allow read: if request.auth != null && (
        resource.data.passengerId == request.auth.uid || isAdmin()
      );
      allow create: if request.auth != null &&
        request.resource.data.passengerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.passengerId == request.auth.uid;
    }
  }
}
